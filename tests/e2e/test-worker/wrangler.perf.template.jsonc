{
  "name": "{{WORKER_NAME}}",
  "main": "index.ts",
  "compatibility_date": "2025-05-06",
  "compatibility_flags": ["nodejs_compat"],
  "account_id": "b8afc92c7a87f699592038b756153d22",

  "vars": {
    "SANDBOX_LOG_LEVEL": "debug",
    "BACKUP_BUCKET_NAME": "sandbox-e2e-test"
  },
  "observability": {
    "enabled": true
  },

  // Performance tests only use the default sandbox type
  "containers": [
    {
      "class_name": "Sandbox",
      "image": "{{IMAGE_SANDBOX}}",
      "name": "{{CONTAINER_NAME}}",
      "max_instances": 50,
      "instance_type": "standard-2"
    }
  ],

  "durable_objects": {
    "bindings": [
      {
        "class_name": "Sandbox",
        "name": "Sandbox"
      }
    ]
  },

  "r2_buckets": [
    {
      "binding": "TEST_BUCKET",
      "bucket_name": "sandbox-e2e-test"
    },
    {
      "binding": "BACKUP_BUCKET",
      "bucket_name": "sandbox-e2e-test"
    }
  ],

  "migrations": [
    {
      "new_sqlite_classes": ["Sandbox"],
      "tag": "v1"
    }
  ]
}
